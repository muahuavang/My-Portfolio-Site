{
  "name": "my-portfolio-site",
  "version": "1.0.0",
  "description": "A modern, responsive portfolio website built with HTML, CSS, and JavaScript following industry best practices",
  "main": "index.html",
  "scripts": {
    "start": "python -m http.server 8000 || python3 -m http.server 8000 || npx serve .",
    "dev": "python -m http.server 8000 || python3 -m http.server 8000 || npx serve .",
    "deploy": "git add . && git commit -m \"Update portfolio site\" && git push origin main",
    "deploy:custom": "echo \"Usage: npm run deploy:custom -- 'Your commit message'\" && git add . && git commit -m \"$npm_config_message\" && git push origin main",
    "build": "tsc",
    "test": "echo \"Open index.html in browser to test\"",
    "lint:html": "npx htmlhint index.html",
    "lint:css": "npx stylelint styles.css",
    "lint:ts": "tsc -p . --noEmit",
    "lint": "npm run lint:html && npm run lint:css && npm run lint:ts",
    "format": "npx prettier --write \"*.{html,css,js,md,ts}\"",
    "optimize:images": "echo \"Use tools like TinyPNG or ImageOptim to compress images\"",
    "validate": "npx html-validate index.html && npx stylelint styles.css && tsc -p . --noEmit",
    "audit": "npm audit --audit-level moderate",
    "clean": "rm -rf node_modules package-lock.json",
    "reinstall": "npm run clean && npm install"
  },
  "keywords": [
    "portfolio",
    "website",
    "responsive",
    "html",
    "css",
    "javascript",
    "github-pages",
    "frontend",
    "web-development",
    "portfolio-template"
  ],
  "author": {
    "name": "Muahua Ulysses Vang",
    "email": "muahuavang@gmail.com",
    "url": "https://github.com/muahuavang"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/muahuavang/My-Portfolio-Site.git",
    "directory": "."
  },
  "homepage": "https://muahuavang.github.io/My-Portfolio-Site/",
  "bugs": {
    "url": "https://github.com/muahuavang/My-Portfolio-Site/issues"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.1.1",
    "html-validate": "^8.12.0",
    "htmlhint": "^1.1.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "serve": "^14.2.1",
    "stylelint": "^16.2.1",
    "stylelint-config-standard": "^36.0.0",
    "stylelint-order": "^6.0.4",
    "typescript": "^5.5.4"
  },
  "dependencies": {},
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.ts": [
      "prettier --write"
    ],
    "*.css": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.html": [
      "htmlhint",
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 80,
    "tabWidth": 2,
    "useTabs": false
  },
  "eslintConfig": {
    "extends": "standard",
    "env": {
      "browser": true,
      "es2021": true
    },
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "rules": {
      "no-console": "warn",
      "no-unused-vars": "warn"
    }
  },
  "stylelint": {
    "extends": "stylelint-config-standard",
    "rules": {
      "selector-class-pattern": null,
      "no-descending-specificity": null
    }
  }
}
