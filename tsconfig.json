{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "sourceMap": false,
    "removeComments": false,
    "outDir": "dist",
    "allowJs": false
  },
  "include": [
    "*.ts"
  ]
}
